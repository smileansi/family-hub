[Unit]
Description=Family Hub Gunicorn Server
After=network.target

[Service]
User=smileansi
Group=smileansi
WorkingDirectory=/home/smileansi/family-hub/family-hub
Environment="PATH=/home/smileansi/family-hub/family-hub/venv/bin"
ExecStart=/home/smileansi/family-hub/family-hub/venv/bin/gunicorn --workers 3 --bind unix:family-hub.sock -m 007 server:app
Restart=always

[Install]
WantedBy=multi-user.target